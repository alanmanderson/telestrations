<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS/Azure App Service configuration for Node.js with WebSocket support.
  This file tells iisnode to run the server and configures URL rewriting
  so that all traffic reaches the Node.js process.
-->
<configuration>
  <system.webServer>
    <!-- iisnode handler for the Node.js entry point -->
    <handlers>
      <add name="iisnode" path="server/dist/index.js" verb="*" modules="iisnode" />
    </handlers>

    <!-- WebSocket support - required for Socket.IO -->
    <webSocket enabled="true" />

    <rewrite>
      <rules>
        <!-- Do not interfere with socket.io polling/websocket requests -->
        <rule name="SocketIO" patternSyntax="ECMAScript" stopProcessing="true">
          <match url="socket.io" />
          <action type="Rewrite" url="server/dist/index.js" />
        </rule>

        <!-- Send all other requests to the Node.js app -->
        <rule name="NodeApp" patternSyntax="ECMAScript" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="server/dist/index.js" />
        </rule>
      </rules>
    </rewrite>

    <iisnode
      nodeProcessCommandLine="node"
      interceptor="&quot;%programfiles%\iisnode\interceptor.js&quot;"
      node_env="production"
      loggingEnabled="true"
      logDirectory="iisnode"
      watchedFiles="web.config"
    />

    <!-- Increase request limits for drawing data uploads -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="1048576" />
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
